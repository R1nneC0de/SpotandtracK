{
  "name": "api",
  "version": "1.0.0",
  "scripts": {
    "dev": "pnpm -F shared build && ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -b",
    "start": "prisma migrate deploy && node dist/index.js",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.11.0",
    "@spotttrack/shared": "workspace:*",
    "bullmq": "^5.4.2",
    "cookie-parser": "^1.4.6",
    "cookie-session": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "fuse.js": "^7.1.0",
    "ioredis": "^5.3.2",
    "node-cron": "^3.0.3",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0",
    "resend": "^6.9.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/cookie-session": "^2.0.49",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "prisma": "^5.11.0",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.0"
  }
}
